# ALOBO Booking Frontend - Environment Configuration Template
# Copy this file to .env and fill in the values

# ==================================================
# API CONFIGURATION
# ==================================================
# Backend API base URL
# For Android emulator: use 10.0.2.2 to access host machine
# For iOS simulator: use localhost
# For physical device: use your machine's local IP address
API_BASE_URL=http://10.0.2.2:8000/api/v1

# ==================================================
# MAP CONFIGURATION
# ==================================================
# Google Maps API key (if using Google Maps)
GOOGLE_MAPS_API_KEY=

# OpenStreetMap is used by default (no API key needed)
# Leave GOOGLE_MAPS_API_KEY empty to use OpenStreetMap

# ==================================================
# FEATURE FLAGS
# ==================================================
# Enable debug mode
DEBUG=true

# Enable analytics tracking
ANALYTICS_ENABLED=false

# ==================================================
# PAYMENT CONFIGURATION
# ==================================================
# VNPay - Deep linking configuration
VNPAY_SCHEME=alobopayment

# Momo - Deep linking configuration
MOMO_SCHEME=alobomomo

# ==================================================
# TIMEZONE
# ==================================================
# All venues are in Hanoi, fixed timezone
TIMEZONE=Asia/Ho_Chi_Minh

{
  "name": "alobo-booking",
  "version": "0.1.0",
  "private": true,
  "description": "Sports facility booking platform for Hanoi, Vietnam",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start --reset-cache",
    "test": "jest",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "test:admin": "node tests/playwright/run-admin-tests.ts",
    "test:admin:debug": "node tests/playwright/run-admin-tests.ts --debug",
    "test:admin:headed": "node tests/playwright/run-admin-tests.ts --headed",
    "test:admin:headless": "node tests/playwright/run-admin-tests.ts --headless",
    "test:admin:firefox": "node tests/playwright/run-admin-tests.ts --browser firefox",
    "test:admin:webkit": "node tests/playwright/run-admin-tests.ts --browser webkit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "playwright:install": "playwright install",
    "playwright:clean": "playwright install --force",
    "test:setup": "node tests/playwright/global-setup.ts",
    "test:teardown": "node tests/playwright/global-teardown.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "axios": "^1.6.5",
    "date-fns": "^3.2.0",
    "expo": "^54.0.33",
    "expo-cli": "^6.3.12",
    "expo-linear-gradient": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-dotenv": "^3.4.11",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-picker": "^7.1.0",
    "react-native-maps": "1.20.1",
    "react-native-modal": "^13.0.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.3.0",
    "react-native-toast-message": "^2.2.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/runtime": "^7.23.9",
    "@expo/metro-config": "~54.0.14",
    "@playwright/test": "^1.40.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/babel-preset": "^0.73.21",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.5",
    "@react-native/typescript-config": "^0.73.1",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^18.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "commander": "^11.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "^19.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}
